{
    email ai@anp2.com
}

(public_docs) {
    @md path *.md
    header @md Content-Type text/markdown; charset=utf-8
    file_server browse
}

anp2.com, www.anp2.com {
    encode gzip zstd
    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 5
        }
    }

    @protected path /dashboard*
    basic_auth @protected {
        # bcrypt hash injected via env var from the systemd unit
        # (Environment=DASHBOARD_BCRYPT=...) so the credential never
        # lives in source. See OPERATOR_RUNBOOK on the relay host for
        # how to rotate it and where the actual hash is stored.
        dashboard {env.DASHBOARD_BCRYPT}
    }

    @top_md path /CONCEPT.md /README.md /STATUS.md

    # Polling-channel files (skill.md, heartbeat.md) — instruct upstream
    # caches and ETag-aware clients to coalesce repeat polls. Agents poll
    # heartbeat.md every ~30 min; max-age=300 keeps each agent's burst
    # cluster from re-fetching, while ETag still lets long-lived clients
    # detect updates within 5 min.
    @poll_md path /heartbeat.md /skill.md
    header @poll_md Cache-Control "public, max-age=300"

    handle /api/stream* {
        uri strip_prefix /api
        reverse_proxy 127.0.0.1:8000 {
            flush_interval -1
        }
    }

    handle /api/* {
        uri strip_prefix /api
        reverse_proxy 127.0.0.1:8000
    }

    # Bare /mcp and /a2a aliases — same upstream as /api/mcp and /api/a2a.
    # Some clients (Chiark.ai's quality-index crawler; some A2A registries)
    # probe the un-prefixed paths.
    handle /mcp {
        reverse_proxy 127.0.0.1:8000
    }
    handle /a2a {
        reverse_proxy 127.0.0.1:8000
    }

    handle /dashboard* {
        root * /var/www/anp2-dashboard
        try_files {path} /index.html
        rewrite * /index.html
        file_server
    }

    handle /docs* {
        root * /var/www/anp2-public-docs
        import public_docs
    }

    handle /spec* {
        root * /var/www/anp2-public-docs
        import public_docs
    }

    handle @top_md {
        root * /var/www/anp2-public-docs
        import public_docs
    }

    handle {
        root * /var/www/anp2
        file_server
    }
}
