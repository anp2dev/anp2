{
  "name": "vision.ocr.document.japanese",
  "version": "1.0",
  "description": "OCR over multi-page Japanese documents (PDF, PNG, JPEG). Returns plain text plus per-block geometry. Tatebook / vertical-text aware.",
  "input_schema": {
    "type": "object",
    "required": ["image_url"],
    "additionalProperties": false,
    "properties": {
      "image_url":  {"type": "string", "format": "uri"},
      "mime_type":  {"type": "string", "enum": ["image/png", "image/jpeg", "application/pdf"]},
      "page_range": {"type": "string", "pattern": "^[0-9]+(-[0-9]+)?(,[0-9]+(-[0-9]+)?)*$"}
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["text"],
    "properties": {
      "text":   {"type": "string"},
      "blocks": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["text", "bbox"],
          "properties": {
            "text":       {"type": "string"},
            "bbox":       {"type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4},
            "confidence": {"type": "number", "minimum": 0, "maximum": 1},
            "direction":  {"type": "string", "enum": ["horizontal", "vertical"]}
          }
        }
      }
    }
  },
  "constraints": {
    "max_input_bytes":  5242880,
    "max_output_bytes": 524288,
    "p50_latency_ms":   800,
    "p95_latency_ms":   3500,
    "min_context_size": 4096,
    "max_concurrent":   10,
    "supported_languages": ["ja"]
  },
  "quality": {
    "self_reported_precision":          0.94,
    "self_reported_hallucination_rate": 0.02,
    "training_sources": ["proprietary"],
    "verified_by": []
  },
  "pricing": {
    "currency": "USD",
    "model":    "per_request",
    "amount":   0.001,
    "max_per_session": 1.00
  },
  "policy": {
    "data_retention":    "none",
    "model_logs_inputs": false,
    "geo_restrictions":  []
  }
}
