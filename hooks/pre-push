#!/usr/bin/env bash
# ANP2 pre-push leak guard.
#
# Refuses to push if `tools/leak_audit.py --full` finds anything.
# This is the publish-path checkpoint — by the time you reach `git push`,
# every leak class must be 0. The --staged pre-commit guard catches NEW
# leaks per-commit; this catches the cumulative history.
#
# Bypass: `--no-verify` works, but using it on a publish-bound push is
# explicitly forbidden by [[feedback-ai-net-leak-audit-procedure]].
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

# ---------------------------------------------------------------------------
# Allowlist guard (default-deny structural safety, 2026-05-31). Refuses to push
# if ANY tracked file is outside the publishable top-level paths. Pairs with the
# allowlist .gitignore: even if an ignore rule is mis-edited or a file was
# force-added (`git add -f`), this blocks the push before anything leaves.
# To publish a NEW top-level path, add it to BOTH this list AND .gitignore.
# ---------------------------------------------------------------------------
ALLOWED_TOPLEVEL='^(\.gitignore|\.github|\.claude-plugin|\.envrc\.template|CHANGELOG\.md|CODE_OF_CONDUCT\.md|CONCEPT\.md|CONTRIBUTING\.md|LICENSE|README\.md|SECURITY\.md|STATUS\.md|datasets|docs|hooks|logo|prototypes|server-config|site|spec|tools)(/|$)'
outside="$(git ls-files | grep -vE "$ALLOWED_TOPLEVEL" || true)"
if [ -n "$outside" ]; then
  echo "pre-push: ALLOWLIST VIOLATION — tracked file(s) outside publishable paths:" >&2
  echo "$outside" | sed 's/^/    /' >&2
  echo "  These must NOT be in the public repo. Either:" >&2
  echo "    • git rm --cached <file>   (untrack; keep locally), or" >&2
  echo "    • if genuinely publishable, add its top-level path to this hook's" >&2
  echo "      ALLOWED_TOPLEVEL and a matching !rule in .gitignore." >&2
  exit 1
fi
echo "pre-push: allowlist guard PASS ($(git ls-files | wc -l | tr -d ' ') tracked files, all within publishable paths)." >&2

if [ ! -f tools/leak_audit.py ]; then
  echo "pre-push: tools/leak_audit.py missing — refusing to push." >&2
  exit 1
fi

echo "pre-push: running leak audit (default + --full)…" >&2
if ! python3 tools/leak_audit.py >/dev/null; then
  echo "pre-push: default-mode leak audit FAILED — push blocked." >&2
  python3 tools/leak_audit.py >&2 || true
  exit 1
fi

if ! python3 tools/leak_audit.py --full >/dev/null; then
  echo "pre-push: --full-mode leak audit FAILED — push blocked." >&2
  echo "         old commits in this branch still contain leak patterns." >&2
  python3 tools/leak_audit.py --full >&2 || true
  exit 1
fi

# Count the commits this push is about to add (so account_health can
# include them in the pacing check). git passes ref info on stdin as:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
#
# Special case: when remote_sha is all-zeros, this is an INITIAL push
# (the remote branch does not exist yet). In that case the entire local
# history is "incoming" but in flag-pattern terms the public-visible event
# is a SINGLE push event (R17 covers it). Counting the full history into
# R7/R8 over-restricts the legitimate initial publication of a previously-
# local repo. We set IS_INITIAL_PUSH=1 in that case and the steady-state
# pacing count is suppressed below.
PUSH_COMMITS=0
PUSH_BURST_1H=0
IS_INITIAL_PUSH=0
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue   # deletion
  fi
  # After a deliberate history rewrite + local prune, the old remote tip may
  # no longer exist locally; a "$remote_sha..$local_sha" range would crash the
  # hook (set -e). Treat an unresolvable remote_sha as a single rewrite event,
  # same as an initial push — the ANP2_REWRITE_PUSH carve-out below governs R7/R8.
  if [ "$remote_sha" != "0000000000000000000000000000000000000000" ] && \
     ! git cat-file -e "${remote_sha}^{commit}" 2>/dev/null; then
    remote_sha=0000000000000000000000000000000000000000
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    IS_INITIAL_PUSH=1
    n=$(git rev-list --count "$local_sha")
  else
    n=$(git rev-list --count "$remote_sha..$local_sha")
  fi
  PUSH_COMMITS=$((PUSH_COMMITS + n))
  # commits authored in the last 1 hour (burst detector)
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    b=$(git rev-list --since="1 hour ago" --count "$local_sha")
  else
    b=$(git rev-list --since="1 hour ago" --count "$remote_sha..$local_sha")
  fi
  PUSH_BURST_1H=$((PUSH_BURST_1H + b))
done

echo "pre-push: this push adds $PUSH_COMMITS commit(s) (last-1h burst: $PUSH_BURST_1H)" >&2

# Burst window: hard cap of 8 commits authored in the last 1h being pushed
# in one go (regardless of how many were already on the server). Catches
# "I just made 20 quick commits" patterns that look bot-like.
if [ "$PUSH_BURST_1H" -gt 8 ]; then
  echo "pre-push: BURST detected — $PUSH_BURST_1H commits authored in last 1h, > 8 cap." >&2
  echo "  Slow down: wait ≥ 1h, OR squash these into fewer commits before pushing." >&2
  echo "  Behavioral discipline rule: [[feedback-ai-net-github-account-discipline]]" >&2
  exit 1
fi

echo "pre-push: leak-audit 36/36 PASS. Running account-health audit…" >&2
# account_health is anonymous-mode (no PAT required, checks external visibility + pacing).
# Steady-state pacing: ANP2_INCOMING_COMMITS adds the about-to-be-pushed
# commits to R7/R8. For an INITIAL push (new branch on remote) the entire
# history would unavoidably exceed the daily cap; we pass 0 instead and
# rely on R17 (push-event count, single event) + R18-R28 to enforce the
# anti-flag invariants. This is the legitimate-first-publication carve-out.
if [ "$IS_INITIAL_PUSH" = "1" ] || [ "${ANP2_REWRITE_PUSH:-}" = "1" ]; then
  # Initial publication OR a deliberate history rewrite (force-push, which already
  # required the single-use force token + passed R24). Both present the whole
  # history as "incoming", but the public-visible event is a SINGLE push that
  # R17/R24 already govern — counting it into R7/R8 is the same over-restriction.
  # The rewrite carve-out is explicit (ANP2_REWRITE_PUSH=1) so it never silently
  # suppresses pacing on a normal push.
  INCOMING_FOR_AUDIT=0
  echo "pre-push: single-event push (initial or rewrite) — R7/R8 use 0 incoming; R17/R24 govern." >&2
else
  INCOMING_FOR_AUDIT=$PUSH_COMMITS
fi
if ! ANP2_INCOMING_COMMITS=$INCOMING_FOR_AUDIT python3 tools/account_health.py --push-mode >/dev/null; then
  echo "pre-push: account-health audit FAILED — push blocked." >&2
  echo "         Active GitHub account is at flag risk. Details:" >&2
  ANP2_INCOMING_COMMITS=$INCOMING_FOR_AUDIT python3 tools/account_health.py --push-mode >&2 || true
  echo "" >&2
  echo "  Resolution: [[feedback-ai-net-github-account-discipline]]" >&2
  echo "  Bypass is forbidden on a publish-bound branch (--no-verify not allowed)." >&2
  exit 1
fi

echo "pre-push: account-health PASS. Verifying defense-stack integrity…" >&2
if [ -x tools/defense_integrity.sh ]; then
  if ! bash tools/defense_integrity.sh verify >/dev/null 2>&1; then
    echo "pre-push: defense-stack DRIFT — push blocked." >&2
    bash tools/defense_integrity.sh verify >&2 || true
    echo "" >&2
    echo "  ▶ If drift is intentional: tools/defense_integrity.sh pin" >&2
    echo "  ▶ Then re-attempt push." >&2
    exit 1
  fi
fi
echo "pre-push: defense-stack integrity PASS. Verifying external-service catalog…" >&2
if [ -x tools/service_discovery.sh ]; then
  if ! bash tools/service_discovery.sh verify >/dev/null 2>&1; then
    echo "pre-push: external-service catalog has unknown host(s) — push blocked." >&2
    bash tools/service_discovery.sh verify >&2 || true
    echo "" >&2
    echo "  ▶ Each unknown host needs a classification:" >&2
    echo "      tools/service_research.sh research <host>" >&2
    echo "  ▶ Then add an entry to tools/service_catalog.json and re-pin." >&2
    exit 1
  fi
fi
echo "pre-push: all gates PASS. Push permitted." >&2
