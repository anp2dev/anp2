#!/usr/bin/env bash
# ANP2 pre-push leak guard.
#
# Refuses to push if `tools/leak_audit.py --full` finds anything.
# This is the publish-path checkpoint — by the time you reach `git push`,
# every leak class must be 0. The --staged pre-commit guard catches NEW
# leaks per-commit; this catches the cumulative history.
#
# Bypass: `--no-verify` works, but using it on a publish-bound push is
# explicitly forbidden by [[feedback-ai-net-leak-audit-procedure]].
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

if [ ! -f tools/leak_audit.py ]; then
  echo "pre-push: tools/leak_audit.py missing — refusing to push." >&2
  exit 1
fi

echo "pre-push: running leak audit (default + --full)…" >&2
if ! python3 tools/leak_audit.py >/dev/null; then
  echo "pre-push: default-mode leak audit FAILED — push blocked." >&2
  python3 tools/leak_audit.py >&2 || true
  exit 1
fi

if ! python3 tools/leak_audit.py --full >/dev/null; then
  echo "pre-push: --full-mode leak audit FAILED — push blocked." >&2
  echo "         old commits in this branch still contain leak patterns." >&2
  python3 tools/leak_audit.py --full >&2 || true
  exit 1
fi

# Count the commits this push is about to add (so account_health can
# include them in the pacing check). git passes ref info on stdin as:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
PUSH_COMMITS=0
PUSH_BURST_1H=0
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue   # deletion
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    n=$(git rev-list --count "$local_sha")
  else
    n=$(git rev-list --count "$remote_sha..$local_sha")
  fi
  PUSH_COMMITS=$((PUSH_COMMITS + n))
  # commits authored in the last 1 hour (burst detector)
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    b=$(git rev-list --since="1 hour ago" --count "$local_sha")
  else
    b=$(git rev-list --since="1 hour ago" --count "$remote_sha..$local_sha")
  fi
  PUSH_BURST_1H=$((PUSH_BURST_1H + b))
done

echo "pre-push: this push adds $PUSH_COMMITS commit(s) (last-1h burst: $PUSH_BURST_1H)" >&2

# Burst window: hard cap of 8 commits authored in the last 1h being pushed
# in one go (regardless of how many were already on the server). Catches
# "I just made 20 quick commits" patterns that look bot-like.
if [ "$PUSH_BURST_1H" -gt 8 ]; then
  echo "pre-push: BURST detected — $PUSH_BURST_1H commits authored in last 1h, > 8 cap." >&2
  echo "  Slow down: wait ≥ 1h, OR squash these into fewer commits before pushing." >&2
  echo "  Behavioral discipline rule: [[feedback-ai-net-github-account-discipline]]" >&2
  exit 1
fi

echo "pre-push: leak-audit 36/36 PASS. Running account-health audit…" >&2
# account_health is anonymous-mode (no PAT required, checks external visibility + pacing).
# The about-to-be-pushed commit count is passed via ANP2_INCOMING_COMMITS so
# R7/R8 evaluate against the combined count.
if ! ANP2_INCOMING_COMMITS=$PUSH_COMMITS python3 tools/account_health.py >/dev/null; then
  echo "pre-push: account-health audit FAILED — push blocked." >&2
  echo "         Active GitHub account is at flag risk. Details:" >&2
  ANP2_INCOMING_COMMITS=$PUSH_COMMITS python3 tools/account_health.py >&2 || true
  echo "" >&2
  echo "  Resolution: [[feedback-ai-net-github-account-discipline]]" >&2
  echo "  Bypass is forbidden on a publish-bound branch (--no-verify not allowed)." >&2
  exit 1
fi

echo "pre-push: account-health PASS. Verifying defense-stack integrity…" >&2
if [ -x tools/defense_integrity.sh ]; then
  if ! bash tools/defense_integrity.sh verify >/dev/null 2>&1; then
    echo "pre-push: defense-stack DRIFT — push blocked." >&2
    bash tools/defense_integrity.sh verify >&2 || true
    echo "" >&2
    echo "  ▶ If drift is intentional: tools/defense_integrity.sh pin" >&2
    echo "  ▶ Then re-attempt push." >&2
    exit 1
  fi
fi
echo "pre-push: defense-stack integrity PASS. Verifying external-service catalog…" >&2
if [ -x tools/service_discovery.sh ]; then
  if ! bash tools/service_discovery.sh verify >/dev/null 2>&1; then
    echo "pre-push: external-service catalog has unknown host(s) — push blocked." >&2
    bash tools/service_discovery.sh verify >&2 || true
    echo "" >&2
    echo "  ▶ Each unknown host needs a classification:" >&2
    echo "      tools/service_research.sh research <host>" >&2
    echo "  ▶ Then add an entry to tools/service_catalog.json and re-pin." >&2
    exit 1
  fi
fi
echo "pre-push: all gates PASS. Push permitted." >&2
