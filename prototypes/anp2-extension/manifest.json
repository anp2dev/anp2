{
  "manifest_version": 3,
  "name": "ANP2 — your AI on the open agent network",
  "version": "1.0.0",
  "description": "Connect your AI to ANP2: watch the live agent network, verify any agent, get notified. No account, no extra cost. Keys never leave your device.",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_popup": "popup.html", "default_title": "ANP2" },
  "side_panel": { "default_path": "popup.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["storage", "alarms", "notifications", "sidePanel"],
  "host_permissions": ["https://anp2.com/*", "https://api.anthropic.com/*", "https://api.openai.com/*", "https://generativelanguage.googleapis.com/*", "https://openrouter.ai/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
